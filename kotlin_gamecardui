import androidx.compose.foundation.Image
import androidx.compose.foundation.background
import androidx.compose.foundation.border
import androidx.compose.foundation.layout.*
import androidx.compose.foundation.shape.RoundedCornerShape
import androidx.compose.material.Icon
import androidx.compose.material.Text
import androidx.compose.material.icons.Icons
import androidx.compose.material.icons.filled.Person
import androidx.compose.material.icons.filled.Star
import androidx.compose.runtime.Composable
import androidx.compose.ui.Alignment
import androidx.compose.ui.Modifier
import androidx.compose.ui.draw.clip
import androidx.compose.ui.graphics.Color
import androidx.compose.ui.layout.ContentScale
import androidx.compose.ui.res.painterResource
import androidx.compose.ui.text.font.FontWeight
import androidx.compose.ui.unit.dp
import androidx.compose.ui.unit.sp

@Composable
fun GamerCardUI(
    gamertag: String = "Player 1",
    gamerscore: Int = 15420,
    zone: String = "Recreation",
    reputation: Int = 5, // Number of filled stars
    avatarResId: Int? = null // Pass an R.drawable.your_avatar here
) {
    // The main card container
    Row(
        modifier = Modifier
            .fillMaxWidth(0.8f) // Takes up 80% of the blade width
            .background(
                color = Color(0xFFD3D3D3).copy(alpha = 0.9f), // Classic light silver/gray background
                shape = RoundedCornerShape(8.dp)
            )
            .border(2.dp, Color(0xFFA0A0A0), RoundedCornerShape(8.dp))
            .padding(12.dp),
        verticalAlignment = Alignment.CenterVertically
    ) {
        // Left Side: Gamer Picture / Avatar
        Box(
            modifier = Modifier
                .size(80.dp)
                .clip(RoundedCornerShape(4.dp))
                .background(Color.White)
                .border(2.dp, Color.Gray, RoundedCornerShape(4.dp)),
            contentAlignment = Alignment.Center
        ) {
            if (avatarResId != null) {
                Image(
                    painter = painterResource(id = avatarResId),
                    contentDescription = "Gamer Picture",
                    contentScale = ContentScale.Crop,
                    modifier = Modifier.fillMaxSize()
                )
            } else {
                // Fallback icon if no avatar is provided
                Icon(
                    imageVector = Icons.Default.Person,
                    contentDescription = "Default Avatar",
                    tint = Color.Gray,
                    modifier = Modifier.size(60.dp)
                )
            }
        }

        Spacer(modifier = Modifier.width(16.dp))

        // Right Side: Gamertag, Gamerscore, Rep, and Zone
        Column(
            modifier = Modifier.fillMaxWidth()
        ) {
            // Gamertag
            Text(
                text = gamertag,
                fontSize = 22.sp,
                fontWeight = FontWeight.Bold,
                color = Color(0xFF333333) // Dark text for contrast
            )

            Spacer(modifier = Modifier.height(4.dp))

            // Gamerscore Row
            Row(verticalAlignment = Alignment.CenterVertically) {
                // A simple text 'G' to mimic the Gamerscore icon
                Text(
                    text = "G",
                    fontSize = 16.sp,
                    fontWeight = FontWeight.ExtraBold,
                    color = Color(0xFF555555),
                    modifier = Modifier
                        .background(Color.White, RoundedCornerShape(12.dp))
                        .padding(horizontal = 6.dp, vertical = 2.dp)
                )
                Spacer(modifier = Modifier.width(4.dp))
                Text(
                    text = gamerscore.toString(),
                    fontSize = 16.sp,
                    fontWeight = FontWeight.Medium,
                    color = Color(0xFF333333)
                )
            }

            Spacer(modifier = Modifier.height(6.dp))

            // Zone and Reputation Row
            Row(
                verticalAlignment = Alignment.CenterVertically,
                modifier = Modifier.fillMaxWidth(),
                horizontalArrangement = Arrangement.SpaceBetween
            ) {
                Text(
                    text = "Zone: $zone",
                    fontSize = 14.sp,
                    color = Color(0xFF555555)
                )

                // Reputation Stars
                Row {
                    for (i in 1..5) {
                        Icon(
                            imageVector = Icons.Default.Star,
                            contentDescription = "Reputation Star",
                            tint = if (i <= reputation) Color(0xFFF2C94C) else Color.Gray,
                            modifier = Modifier.size(16.dp)
                        )
                    }
                }
            }
        }
    }
}
